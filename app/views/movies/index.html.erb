<h1>Movies</h1>

<ul>
<% @movies.each do |movie| %>
  <li>
    <strong><%= movie.title %></strong> (<%= movie.rating %>)
    <%= total_gross(movie) %>
  </li>
    <p><%= movie.description %></p>
    <p><%= truncate(movie.description, length: 40, separator: "  ") %></p>
    <p><%= year_of(movie) %></p>
<% end %>
</ul>
