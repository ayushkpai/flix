<section class="movie-details">
  <div class="image"><%= image_tag @movie.image_file_name %></div>
  <div class="details">
    <h1><%= @movie.title %></h1>
    <h2><%= year_of(@movie) %> &bull; <%= @movie.rating %></h2>
    <p><%= @movie.description %></p>
    <table>
      <tr>
        <th>Director:</th>
        <td><%= @movie.director %></td>
      </tr>
      <tr>
        <th>Duration:</th>
        <td><%= @movie.duration %></td>
      </tr>
      <tr>
        <th>Total Gross:</th>
        <td><%= total_gross(@movie) %></td>
      </tr>
    </table>
    <div class="reviews">
      <%= average_stars(@movie) %>
      <%= link_to "Write Review", new_movie_review_path(@movie), class: "btn btn-success" %>
      <%= link_to "Reviews", movie_reviews_path(@movie), class: "btn btn-success" %>
      
      <% if current_user_admin? %>
        <%= link_to "Edit", edit_movie_path(@movie), class: "btn btn-secondary" %>
        <%= link_to "Delete", movie_path(@movie), class: "btn btn-outline-danger", data: { turbo_method: :delete, turbo_confirm: "Are you sure" } %>
      <% end %>
    </div>
  </div>
</section>
