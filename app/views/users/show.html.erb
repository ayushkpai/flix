<section class="user">
    <h1><%= @user.name %></h1>
    <h5><%= mail_to(@user.email) %></h5>
    <% if current_user?(@user) %>
        <%= link_to "Edit", edit_user_path(@user), class: "btn btn-secondary" %>
        <%= link_to "Delete", @user, class: "btn btn-outline-danger", data: { turbo_method: :delete, turbo_confirm: "Are you sure" } %>
    <% end %>

    <% if @reviews.present? %>
        <h2 class="mt-5 mb-4">Reviews</h2>
        <div class="reviews-list">
            <% @reviews.each do |review| %>
            <div class="review-card">
            <div class="review-left">
                <div class="image"><%= image_tag review.movie.image_file_name %></div>
                <div class="movie-info"><%= link_to review.movie.title, review.movie, class: "movie-title" %></div>
            </div>
            </div>
            <% end %>
        </div>
    <% end %>

    <% if @favourite_movies.present? %>
        <h3>Favourite Movies</h3>
        <div class="favourite-movies">
            <% @favourite_movies.each do |movie| %>
                <%= link_to image_tag(movie.image_file_name), movie %>
            <% end %>
        </div>
    <% end %>
</section>
